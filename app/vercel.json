{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/oversikt/art/:id",
      "destination": "/oversikt/art/[id]"
    },
    {
      "source": "/oversikt/:kategori",
      "destination": "/oversikt/[kategori]"
    },
    {
      "source": "/historikk/:id",
      "destination": "/historikk/[id]"
    }
  ]
}

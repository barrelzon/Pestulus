# Port backend lytter på lokalt (Render setter PORT automatisk)
PORT=8787

# --- Vision-leverandør: Google Gemini ---
# Hent nøkkel i Google AI Studio (aistudio.google.com -> Get API key).
# Nøkkelen skal ALDRI inn i klienten eller i git.
VISION_API_KEY=

# Basis-URL UTEN modellnavn - vision.ts bygger {URL}/{MODEL}:generateContent
VISION_API_URL=https://generativelanguage.googleapis.com/v1beta/models

# Flash-tier: rask og billig, god nok presisjon for de fleste arter. Bytt til
# en Pro-modell (f.eks. gemini-3.1-pro-preview) for bedre resonnering på
# tvetydige arter, jf. usikker-håndteringen - krever betaling aktivert i
# Gemini-prosjektet.
VISION_MODEL=gemini-3.5-flash

# Konfidens-terskler for status "treff" (under disse settes status til "usikker"
# og flere kandidater vises i appen):
# - CONFIDENCE_THRESHOLD: toppkandidaten må ha minst denne konfidensen.
# - CONFIDENCE_MARGIN_THRESHOLD: avstanden mellom nr. 1 og nr. 2 må være minst
#   så stor (for liten avstand = de er for like til å skille sikkert).
CONFIDENCE_THRESHOLD=0.7
CONFIDENCE_MARGIN_THRESHOLD=0.15

# Admin-dashboard. ADMIN_PASSWORD må settes på Render for /admin.
ADMIN_PASSWORD=

# Persistent admin-lagring. La stå tomt lokalt for backend/src/data.
# På Render: attach persistent disk og sett f.eks.
# ADMIN_DATA_DIR=/var/data/pestulus-admin
ADMIN_DATA_DIR=
